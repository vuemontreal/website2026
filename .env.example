# TheMeetHub API — dev: localhost, prod: URL déploiement
NUXT_THEMEETHUB_API_URL=http://localhost:3000

# Images (optionnel) — URLs Unsplash, Pexels ou vos propres images
# NUXT_HERO_IMAGE_URL=https://images.unsplash.com/photo-xxx?w=1200&q=80
# NUXT_COMMUNITY_IMAGE_URL=https://images.unsplash.com/photo-xxx?w=800&q=80

# Newsletter — URL du formulaire (Formspree, Mailchimp, Buttondown, etc.)
# NUXT_NEWSLETTER_URL=https://formspree.io/f/xxxxx
# NUXT_NEWSLETTER_EMAIL_FIELD=email  # ou EMAIL pour Mailchimp
